<SchermataTransazioni>:
    MDBoxLayout:
        orientation: "vertical"
        md_bg_color: 0.078, 0.078, 0.122, 1

        MDBoxLayout:
            orientation: "horizontal"
            size_hint: 1, None
            height: dp(64)
            padding: [dp(16), dp(10), dp(16), dp(10)]
            md_bg_color: 0.10, 0.10, 0.16, 1
            spacing: dp(10)

            MDIcon:
                icon: "currency-usd"
                theme_text_color: "Custom"
                text_color: 0.39, 0.31, 1, 1
                font_size: sp(28)
                size_hint_x: None
                width: dp(32)

            MDLabel:
                text: "Transazioni"
                font_style: "H6"
                bold: True
                theme_text_color: "Custom"
                text_color: 1, 1, 1, 1

            Widget:

            MDIconButton:
                icon: "logout"
                theme_text_color: "Custom"
                text_color: 0.6, 0.6, 0.6, 1
                ripple_color: 1, 1, 1, 0.15
                on_press: root.vai_al_login()

        # ── Barra filtro categoria ───────────────────────────
        MDBoxLayout:
            size_hint: 1, None
            height: dp(48)
            padding: [dp(12), dp(6), dp(12), dp(6)]
            md_bg_color: 0.10, 0.10, 0.16, 1
            spacing: dp(8)

            MDIconButton:
                icon: "filter-variant"
                theme_text_color: "Custom"
                text_color: 0.39, 0.31, 1, 1
                size_hint_x: None
                width: dp(36)
                on_release: root.apri_filtro_categoria()

            MDLabel:
                id: label_filtro_attivo
                text: "Tutte le categorie"
                theme_text_color: "Custom"
                text_color: 0.75, 0.75, 0.75, 1
                font_style: "Body2"
                size_hint_x: 1

            MDIconButton:
                id: btn_reset_filtro
                icon: "close-circle"
                theme_text_color: "Custom"
                text_color: 0.6, 0.3, 0.3, 1
                size_hint_x: None
                width: dp(36)
                opacity: 0
                disabled: True
                on_release: root.reset_filtro_categoria()

        ScrollView:
            size_hint: 1, 1

            GridLayout:
                id: contenitore
                cols: 1
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(12)
                padding: dp(16)

        # =============================================
        # AGGIUNTA: bottone VOCALE affiancato ad AGGIUNGI TRANSAZIONE
        # =============================================
        MDBoxLayout:
            size_hint: 1, None
            height: dp(80)
            padding: [dp(16), dp(12), dp(16), dp(12)]
            md_bg_color: 0.10, 0.10, 0.16, 1
            spacing: dp(10)

            MDRaisedButton:
                text: "  AGGIUNGI TRANSAZIONE"
                icon: "plus"
                size_hint_x: 0.62
                height: dp(50)
                md_bg_color: 0.39, 0.31, 1, 1
                ripple_color: 1, 1, 1, 0.2
                font_size: sp(14)
                on_press: root.aggiungi_transazione()

            MDRaisedButton:
                id: btn_vocale
                text: "  VOCALE"
                icon: "microphone"
                size_hint_x: 0.38
                height: dp(50)
                md_bg_color: 0.2, 0.7, 0.4, 1
                ripple_color: 1, 1, 1, 0.2
                font_size: sp(14)
                on_press: root.aggiungi_transazione_vocale()
        # =============================================
        # FINE AGGIUNTA VOCALE
        # =============================================
